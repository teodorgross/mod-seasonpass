[worldserver]

########################################
# mod-seasonpass v3 — Konfiguration
# Community-Pass: ALLES kostenlos, beide Pfade fuer alle.
########################################

SeasonPass.Enable = 1
SeasonPass.Season = 1
SeasonPass.PointsPerTier = 100
SeasonPass.MaxTier = 100

########################################
# Punktequellen
########################################
SeasonPass.Points.Quest = 10
SeasonPass.Points.Kill = 1
SeasonPass.Points.EliteKill = 5
SeasonPass.Points.BossKill = 100
SeasonPass.Points.RareKill = 25
SeasonPass.Points.LevelUp = 50
SeasonPass.Points.DailyLogin = 50
SeasonPass.Points.PvPKill = 10
SeasonPass.Points.DuelWin = 5

# Anti-Farm: dasselbe PvP-Opfer zaehlt nur alle X Sekunden
SeasonPass.PvP.VictimCooldown = 300

# Login-Serie: Extra-Punkte pro Serientag (gedeckelt bei 10 Tagen)
SeasonPass.Streak.BonusPerDay = 5

########################################
# Prestige (ab Maximalstufe: Pass neu starten, Stern verdienen)
########################################
SeasonPass.Prestige.Enable = 1

########################################
# Bonus-Wochenende (Samstag + Sonntag, Serverzeit)
########################################
SeasonPass.Weekend.Enable = 1
SeasonPass.Weekend.PointsPercent = 200
SeasonPass.Weekend.XPPercent = 150

########################################
# Levelkisten (alle 10 Level: Gold, ab 20 zusaetzlich Tasche per Post)
########################################
SeasonPass.LevelChest.Enable = 1
SeasonPass.LevelChest.GoldPer10Levels = 50000
SeasonPass.LevelChest.BagItem = 21841

########################################
# Wochenziele (3 rotierende Aufgaben pro Woche, aus 40 Definitionen)
########################################
SeasonPass.Weekly.Enable = 1

########################################
# Runen (12 Dauerbuffs + 12 NEUE Faehigkeiten, Kauf bei Runenmeisterin Sela)
########################################
SeasonPass.Runes.Enable = 1
# Basis-Slots; Extra-Slots kommen automatisch ab BP-Stufe 25/50/75
SeasonPass.Runes.BaseSlots = 3

########################################
# Weltboss-Rotation (Alptraumdrachen & Co, siehe seasonpass_worldboss)
########################################
SeasonPass.WorldBoss.Enable = 1
SeasonPass.WorldBoss.IntervalHours = 6
SeasonPass.WorldBoss.DespawnMinutes = 120
SeasonPass.WorldBoss.BonusPoints = 250
# Weltbuff fuer ALLE Online-Spieler beim Boss-Kill (22888 = Schlachtruf der
# Drachentoeter, 0 = aus)
SeasonPass.WorldBoss.WorldBuffSpell = 22888

########################################
# Zonen-Event (rotiert, doppelte Punkte in der aktiven Zone)
########################################
SeasonPass.ZoneEvent.Enable = 1
SeasonPass.ZoneEvent.RotationHours = 3
SeasonPass.ZoneEvent.PointsPercent = 200

########################################
# Kopfgeld des Tages / Dungeon der Woche / Entdeckungen / Erfolge
########################################
SeasonPass.Bounty.Enable = 1
SeasonPass.DungeonWeek.Enable = 1
SeasonPass.Discoveries.Enable = 1
SeasonPass.Achievements.Enable = 1

# Traumtausch: 1x pro Woche ein Wochenziel neu wuerfeln (0/1)
SeasonPass.Weekly.RerollEnable = 1

########################################
# Zufallskisten (Pool: seasonpass_chest_loot, 800+ Items aus deiner DB)
# Nach Erreichen der Maximalstufe droppen Kisten von Gegnern — Endlos-Endgame!
########################################
SeasonPass.Chest.Enable = 1
SeasonPass.Chest.DropChanceKillPct = 2
SeasonPass.Chest.DropChanceElitePct = 10
SeasonPass.Chest.DropChanceBossPct = 100
# Chance, dass ein Boss eine legendaere statt epische Kiste gibt
SeasonPass.Chest.LegendaryFromBossPct = 10
# Kistenfieber (Pity): Basis-Epicchance pro Item und Steigerung pro Kiste ohne Episches
SeasonPass.Chest.EpicChanceBasePct = 15
SeasonPass.Chest.PityStepPct = 5

########################################
# Traumsturm (zufaellige 15-Minuten-Stunde: dreifache Punkte)
########################################
SeasonPass.Storm.Enable = 1
SeasonPass.Storm.PointsPercent = 300

########################################
# Saison-Erbe: permanenter Punktebonus pro Prestige-Stern (Prozent)
########################################
SeasonPass.Legacy.PointsPercentPerPrestige = 2

########################################
# Wochen-Mutatoren (Open-World-Affixe, siehe seasonpass_mutators)
########################################
SeasonPass.Mutators.Enable = 1

########################################
# Sonstiges
########################################
SeasonPass.AnnounceTier = 1
SeasonPass.AnnounceRareKill = 1

# Playerbots vom Season Pass ausschliessen (Performance!)
SeasonPass.IgnoreBots = 1
SeasonPass.BotAccountPrefixes = RNDBOT,ADDCLASS
